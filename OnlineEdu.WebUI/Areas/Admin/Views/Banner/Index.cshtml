@model List<ResultBannerDto>
@{
    ViewData["Title"] = "Banner Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@{
    int count = 0;
}
<table class="table table-hover">
    <tr>
        <th>#</th>
        <th>Başlık</th>
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        count++;
        <tr>
            <td>@count</td>
            <td><img src="@item.ImageUrl" style="height:75px;width:75px" />   @item.Title</td>
            <td>
                <a asp-action="UpdateBanner" asp-route-id="@item.BannerID" asp-controller="Banner" asp-area="Admin" class="btn btn-outline-info">Güncelle</a>

                <a asp-action="DeleteBanner" asp-controller="Banner" asp-area="Admin" asp-route-id="@item.BannerID" class="btn btn-outline-danger">Sil</a>
            </td>

        </tr>
    }
</table>
<br />
<a asp-action="CreateBanner" asp-controller="Banner" asp-area="Admin" class="btn btn-outline-primary">Yeni Banner Ekle</a>
